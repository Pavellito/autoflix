# Get your free Gemini API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# AI Model selection (uses the same GEMINI_API_KEY)
# Options: gemini-flash (default, fast), gemma-4 (Google Gemma 4 31B, powerful reasoning)
AI_MODEL=gemma-4

# Groq API key for fallback (optional) - https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# YouTube Data API key for video search - https://console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key_here

# Supabase - https://supabase.com
NEXT_PUBLIC_SUPABASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Supabase Service Role Key (for admin writes - never expose to client!)
# Get from: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Admin secret for protecting /api/admin/* endpoints
ADMIN_SECRET=your_admin_secret_here
